# 1. تحديد نظام التشغيل والبيئة الأساسية (نود نسخة 18 خفيفة)
FROM node:18-alpine

# 2. تحديد مجلد العمل الداخلي بداخل الحاوية
WORKDIR /app

# 3. نسخ ملفات الحزم أولاً لتسريع عملية البناء اللاحقة
COPY package*.json ./

# 4. تثبيت المكتبات البرمجية المذكورة في الـ package.json تلقائياً داخل الحاوية
RUN npm install

# 5. نسخ بقية كود المشروع (الملفات والمجلدات) إلى داخل الحاوية
COPY . .

# 6. فتح المنفذ رقم 3000 لتسمح للحاوية باستقبال الطلبات عبر الإنترنت
EXPOSE 3000

# 7. الأمر النهائي الذي سيقوم بتشغيل خادم الـ Node عند إقلاع الحاوية
CMD ["node", "src/server.js"]
